# =============================================================================
# OpenClaw on Sevalla — Environment Variables
# Copy to .env and fill in your values
# On Sevalla: set these as "Secrets" in the application settings
# =============================================================================

# --- Gateway Auth ---
# Strong random token for Control UI + API access
# Generate: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=changeme

# --- AI Provider Keys ---
# At least one is required
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...

# --- Salesforce Auth ---
# Auth URL format from: sf org display --verbose --target-org <alias>
# Or use sfdx auth url: sfdxAuthUrl://...
# SF_PROD_AUTH_URL=
# SF_DEV_AUTH_URL=
# SF_QA_AUTH_URL=

# --- Channel Integrations ---
# Discord bot token (create at https://discord.com/developers)
# DISCORD_BOT_TOKEN=

# Telegram bot token (from @BotFather)
# TELEGRAM_BOT_TOKEN=

# --- Google Workspace (gog CLI) ---
# GOG_CLIENT_ID=
# GOG_CLIENT_SECRET=

# --- Optional ---
# NODE_ENV=production
# TZ=America/Denver
