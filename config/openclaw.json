{
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },

  "gateway": {
    "port": 8080,
    "bind": "lan",
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "allowedOrigins": ["https://revops-revx-ae440.sevalla.app"],
      "dangerouslyDisableDeviceAuth": true
    }
  },

  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "daily",
      "atHour": 4
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-opus-4-6"
      },
      "models": {
        "anthropic/claude-opus-4-6": {
          "alias": "opus"
        }
      },
      "workspace": "/home/node/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "60m",
        "target": "last"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    }
  },

  "channels": {
    "slack": {
      "enabled": true,
      "mode": "socket",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "allowlist",
      "channels": {
        "C08NBP2EL6T": { "allow": true, "requireMention": true }
      }
    }
  },

  "tools": {
    "exec": {
      "security": "full"
    }
  },

  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": true
        },
        "session-memory": {
          "enabled": true
        }
      }
    }
  },

  "commands": {
    "native": "auto",
    "restart": true
  },

  "ui": {
    "seamColor": "#F59E0B",
    "assistant": {
      "name": "RevX",
      "avatar": "⚡"
    }
  },

  "env": {
    "vars": {
      "TZ": "America/Denver"
    }
  }
}
