{
  "auth": {
    "profiles": {
      "anthropic:default": {
        "provider": "anthropic",
        "mode": "token"
      }
    }
  },

  "gateway": {
    "port": 8080,
    "bind": "lan",
    "auth": {
      "mode": "token"
    },
    "controlUi": {
      "allowedOrigins": ["https://revops-revx-ae440.sevalla.app", "http://localhost:5173"],
      "dangerouslyDisableDeviceAuth": true
    }
  },

  "browser": {
    "enabled": true,
    "headless": true,
    "noSandbox": true,
    "defaultProfile": "openclaw",
    "ssrfPolicy": {
      "dangerouslyAllowPrivateNetwork": true
    }
  },

  "session": {
    "dmScope": "per-channel-peer",
    "reset": {
      "mode": "daily",
      "atHour": 4
    }
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "anthropic/claude-opus-4-6"
      },
      "models": {
        "anthropic/claude-opus-4-6": {
          "alias": "opus"
        }
      },
      "workspace": "/home/node/.openclaw/workspace",
      "compaction": {
        "mode": "safeguard"
      },
      "heartbeat": {
        "every": "60m",
        "target": "last"
      },
      "maxConcurrent": 4,
      "subagents": {
        "maxConcurrent": 8
      }
    },
    "list": [
      {
        "id": "revx",
        "name": "RevX",
        "default": true,
        "workspace": "/home/node/.openclaw/workspace",
        "identity": {
          "name": "RevX",
          "emoji": "⚡"
        },
        "subagents": {
          "allowAgents": ["sf-dev", "spec-ops"]
        }
      },
      {
        "id": "spec-ops",
        "name": "Spec Ops",
        "workspace": "/home/node/.openclaw/workspace/spec-ops",
        "model": "anthropic/claude-sonnet-4-20250514",
        "identity": {
          "name": "Spec Ops",
          "emoji": "🎯"
        },
        "heartbeat": {
          "every": "0"
        }
      },
      {
        "id": "sf-dev",
        "name": "Code Monkey",
        "workspace": "/home/node/.openclaw/workspace/sf-dev",
        "model": "anthropic/claude-sonnet-4-20250514",
        "identity": {
          "name": "Code Monkey",
          "emoji": "🐒"
        },
        "heartbeat": {
          "every": "0"
        }
      }
    ]
  },

  "channels": {
    "slack": {
      "enabled": true,
      "mode": "socket",
      "dmPolicy": "open",
      "allowFrom": ["*"],
      "groupPolicy": "allowlist",
      "channels": {
        "C08NBP2EL6T": { "allow": true, "requireMention": true },
        "C0AN7DGC6M6": { "allow": true, "requireMention": true }
      }
    }
  },

  "tools": {
    "exec": {
      "security": "full"
    }
  },

  "hooks": {
    "internal": {
      "enabled": true,
      "entries": {
        "boot-md": {
          "enabled": true
        },
        "session-memory": {
          "enabled": true
        }
      }
    }
  },

  "commands": {
    "native": "auto",
    "restart": true
  },

  "ui": {
    "seamColor": "#F59E0B",
    "assistant": {
      "name": "RevX",
      "avatar": "⚡"
    }
  },

  "env": {
    "vars": {
      "TZ": "America/Denver"
    }
  }
}
